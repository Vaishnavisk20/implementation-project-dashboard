{
  "name": "implementation-project-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run start",
    "build": "npm --prefix apps/api run build && npm --prefix apps/web run build",
    "lint": "npm --prefix apps/api run lint && npm --prefix apps/web run lint",
    "colima:start": "colima start -f",
    "db:up": "docker compose up -d postgres",
    "db:native:start": "LC_ALL=en_US.UTF-8 /usr/local/opt/postgresql@16/bin/postgres -D /usr/local/var/postgresql@16",
    "db:migrate": "npm --prefix apps/api run prisma:migrate",
    "db:seed": "npm --prefix apps/api run seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
